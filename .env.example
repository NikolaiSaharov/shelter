# Скопируйте этот файл в .env и заполните значения.
# После этого достаточно: .\run.ps1  или  python manage.py runserver

# Django
SECRET_KEY=замените-на-длинную-случайную-строку
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (локально)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_NAME=AnimalShelterDB
PG_USER=postgres
PG_PASSWORD=1

# Почта Mail.ru SMTP (для чеков, уведомлений)
MAILRU_EMAIL_USER=your-mail@mail.ru
MAILRU_EMAIL_PASSWORD=пароль-приложения-из-настроек-mail-ru
MAILRU_EMAIL_PORT=465
